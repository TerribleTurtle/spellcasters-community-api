{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://spellcasters.gg/schemas/v2/map_chests.schema.json",
  "title": "Map Chests",
  "description": "Chest spawn locations and rewards for a specific map.",
  "type": "object",
  "allOf": [
    { "$ref": "definitions/core.schema.json#/definitions/identity" },
    { "$ref": "definitions/core.schema.json#/definitions/meta" },
    { "$ref": "definitions/core.schema.json#/definitions/assets" }
  ],
  "properties": {
    "chests": {
      "type": "array",
      "description": "List of chest spawn points on this map.",
      "items": {
        "type": "object",
        "required": ["location", "rarity", "tier", "reward_entity_id", "reward_type"],
        "properties": {
          "location": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Freeform label for the chest position on the map."
          },
          "rarity": {
            "type": "string",
            "enum": ["Common", "Epic", "Legendary"],
            "description": "Chest rarity tier category."
          },
          "tier": {
            "type": "string",
            "enum": ["T1", "T2", "T3", "T4"],
            "description": "Granular power tier within the rarity category."
          },
          "reward_entity_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "entity_id of the unit or spell rewarded by this chest."
          },
          "reward_type": {
            "type": "string",
            "enum": ["Unit", "Spell"],
            "description": "Which entity collection the reward belongs to."
          },
          "spawn_time_seconds": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "description": "Match times (in seconds) when this chest spawns. Optional — for future use."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["chests"],
  "unevaluatedProperties": false
}
